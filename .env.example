# Copy to .env and fill from Supabase → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use either legacy anon JWT or new publishable key (sb_publishable_…)
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Optional alias (same value as above if you prefer the name from the dashboard)
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Comma-separated emails that always get "manager" role (full app access).
# Otherwise use Supabase Dashboard → Authentication → Users → user →
# App metadata: { "role": "manager" } (trusted; not settable from client sign-up).
# VITE_MANAGER_EMAILS=ops@yourcompany.com
